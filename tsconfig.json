{
  "compilerOptions": {
    "module": "node16",
    "esModuleInterop": true,
    "target": "es2015",
    "declaration": true,
    "noImplicitAny": true,
    "moduleResolution": "node16",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules/*"]
}
