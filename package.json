{
  "name": "query-cast",
  "version": "2.0.2",
  "description": "Query params parser and cast micro-library",
  "repository": {
    "type": "git",
    "url": "git@github.com:RomiC/query-cast.git"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p .",
    "lint": "eslint src specs",
    "lint:fix": "npm run lint -- --fix",
    "test": "vitest --config vitest.config.ts run"
  },
  "types": "./dist/index.d.ts",
  "dependencies": {
    "typeable": "2.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",

    "husky": "9.1.7",
    "lint-staged": "17.0.6",
    "prettier": "^3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "query",
    "querystring",
    "searchparams",
    "query parameters",
    "url parser",
    "query parser"
  ],
  "lint-staged": {
    "*.ts": "npm run lint:fix"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm test"
    }
  }
}
