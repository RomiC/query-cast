{
  "name": "query-cast",
  "version": "2.0.2",
  "description": "Query params parser and cast micro-library",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git@github.com:RomiC/query-cast.git"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "build:test": "tsdown -c tsdown.tests.config.ts",
    "lint": "eslint src specs",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"src/**/*.ts\" \"specs/**/*.js\" \"scripts/**/*.{cjs,mjs}\" \"eslint.config.js\" \"tsconfig.json\" \"*.config.ts\"",
    "pretest": "npm run build:test",
    "pretest:smoke": "npm run build",
    "test": "c8 --reporter=text --reporter=lcov --include=dist node --test specs/*.spec.js",
    "test:no-coverage": "node --test specs/*.spec.js",
    "test:smoke": "node ./scripts/smoke-cjs.cjs && node ./scripts/smoke-esm.mjs"
  },
  "dependencies": {
    "typeable": "2.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "c8": "^11.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "9.1.7",
    "lint-staged": "17.0.6",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "keywords": [
    "query",
    "querystring",
    "searchparams",
    "query parameters",
    "url parser",
    "query parser"
  ],
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "npm run lint:fix"
    ],
    "*.js": "prettier --write",
    "*.{cjs,mjs}": "prettier --write",
    "*.{json,md}": "prettier --write"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm test"
    }
  },
  "overrides": {
    "yargs": "^18.0.0"
  }
}
